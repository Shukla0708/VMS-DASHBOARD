<mvc:View
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:f="sap.f"
  controllerName="com.yms.fiori.controller.ManifestList"
  displayBlock="true">

  <Page
    id="manifestListPage"
    title="Manifest Overview"
    class="sapUiContentPadding">

    <!-- ── Filter Bar ── -->
    <subHeader>
      <Bar>
        <contentLeft>
          <SearchField
            id="manifestSearch"
            placeholder="Search Manifest No..."
            width="220px"
            liveChange=".onSearch" />
        </contentLeft>
        <contentRight>
          <Button
            text="Go"
            type="Emphasized"
            press=".onSearch" />
          <Button
            icon="sap-icon://refresh"
            tooltip="Refresh"
            press=".onRefresh" />
        </contentRight>
      </Bar>
    </subHeader>

    <!-- ── Manifest Table ── -->
    <content>
      <Table
        id="manifestTable"
        items="{
          path: '/ManifestHeader',
          parameters: {
            $expand: '_Vehicles',
            $orderby: 'zzmanifest_no desc'
          }
        }"
        mode="None"
        growing="true"
        growingThreshold="20"
        growingScrollToLoad="true"
        busyIndicatorDelay="0"
        noDataText="No manifests found">

        <headerToolbar>
          <OverflowToolbar>
            <Title text="Manifests" level="H3" />
            <ToolbarSpacer />
            <Text id="manifestCountText" text="" class="sapUiSmallMarginEnd" />
          </OverflowToolbar>
        </headerToolbar>

        <columns>
          <Column width="14rem">
            <Text text="Manifest No" />
          </Column>
          <Column width="6rem" hAlign="Center">
            <Text text="Vehicles" />
          </Column>
          <Column>
            <Text text="" />
          </Column>
        </columns>

        <items>
          <ColumnListItem
            type="Navigation"
            press=".onManifestPress">
            <cells>
              <ObjectIdentifier
                title="{zzmanifest_no}"
                titleActive="false" />
              <ObjectNumber
                number="{NoOfVehicles}"
                unit="veh"
                state="Information" />
              <Button
                icon="sap-icon://arrow-right"
                type="Transparent"
                press=".onManifestPress" />
            </cells>
          </ColumnListItem>
        </items>

      </Table>
    </content>

  </Page>
</mvc:View>
